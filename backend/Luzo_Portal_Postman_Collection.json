				{
					"name": "Update Status - Shortlist",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{recruiterToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/recruiter/applications/{{applicationId}}?status=SHORTLISTED&notes=Great candidate!",
							"host": ["{{baseUrl}}"],
							"path": ["api", "recruiter", "applications", "{{applicationId}}"],
							"query": [
								{
									"key": "status",
									"value": "SHORTLISTED"
								},
								{
									"key": "notes",
									"value": "Great candidate!"
								}
