							"mode": "raw",
							"raw": "{\n  \"location\": \"New York\",\n  \"minExperience\": 2,\n  \"maxExperience\": 5,\n  \"education\": \"Bachelor\",\n  \"skills\": [\"Java\", \"Spring Boot\"]\n}"
