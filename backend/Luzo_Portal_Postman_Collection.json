						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"location\": \"New York\",\n  \"yearsOfExperience\": 3,\n  \"education\": \"Bachelor's in Computer Science\",\n  \"skills\": [\"Java\", \"Spring Boot\", \"PostgreSQL\"]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register/user",
